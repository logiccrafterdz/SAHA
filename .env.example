# SAHA Environment Variables
# Copy this file to .env and fill in your actual values

# ─── PostgreSQL ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=saha
POSTGRES_USER=saha
POSTGRES_PASSWORD=changeme

# ─── Redis (Event Bus) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Model Providers ──────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4x)
OPENAI_API_KEY=sk-proj-...

# Google (Gemini)
GOOGLE_API_KEY=AIzaSy...

# ─── Default Providers (Configurable via Profiles) ────────
SAHA_DEFAULT_PROVIDER_CLAUDE=claude-3-5-sonnet
SAHA_DEFAULT_PROVIDER_OPENAI=gpt-4o
SAHA_DEFAULT_PROVIDER_GEMINI=gemini-1.5-pro

# ─── Feature Flags ────────────────────────────────────────
SAHA_ENABLE_PROVIDER_CLAUDE=true
SAHA_ENABLE_PROVIDER_OPENAI=true
SAHA_ENABLE_PROVIDER_GEMINI=true

# ─── Service Ports ──────────────────────────────────────
EXECUTION_API_PORT=8001
VENDOR_API_PORT=8002
EVAL_API_PORT=8003
BUS_PORT=8090

# ─── Eval Harness ───────────────────────────────────────
# Seconds before hot storage expires → warm
HOT_STORAGE_TTL_DAYS=30
WARM_STORAGE_TTL_DAYS=180

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
